{
  "main": "dist-electron/main.js",
  "name": "mysimpledb-desktop",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "copy:electron": "node scripts/copy-electron-files.cjs",
    "dev": "npm run build:electron && concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json && npm run copy:electron",
    "electron": "npm run build:electron && electron .",
    "dist:mac": "npm run build && npm run build:electron && electron-builder --mac dmg",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.mysimpledb.desktop",
    "productName": "MySimpleDB",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns"
    },
    "dmg": {
      "title": "MySimpleDB Installer",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 140,
          "y": 190
        },
        {
          "x": 400,
          "y": 190,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "concurrently": "^10.0.3",
    "electron": "^35.7.5",
    "electron-builder": "^26.15.2",
    "electron-rebuild": "^3.2.9",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "chokidar": "^5.0.0"
  }
}
